# ============================================================
# Bradix NUC — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# ─── n8n Configuration ───────────────────────────────────────
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_USER=andrew
N8N_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING
WEBHOOK_URL=http://localhost:5678/

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=bradix
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=n8n

# ─── Email / SMTP ────────────────────────────────────────────
# For Gmail: use App Password (not your main password)
# For Outlook/Hotmail: use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SENDER=Bradix Guardian <your-email@gmail.com>

# ─── Alert Recipients ────────────────────────────────────────
ALERT_EMAIL_PRIMARY=bts@outlook.com
ALERT_EMAIL_SECONDARY=cherylbruder@icloud.com

# ─── Jetson AI Endpoint ──────────────────────────────────────
# Set to the Jetson's IP address on your local network
# Default hostname if using mDNS: jetson.local
JETSON_ENDPOINT=http://192.168.1.XXX:8000

# ─── GitHub / Case Data Sync ─────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_GITHUB_PERSONAL_ACCESS_TOKEN
GITHUB_REPO=toronto192020/Bradyx
CASE_DATA_PATH=/opt/bradix/case-data

# ─── SuresafeGO Integration ──────────────────────────────────
# SuresafeGO does not have a public API.
# Configure your SuresafeGO account to send alerts to a
# dedicated email address, then set that address here.
# The monitor will watch that inbox for fall/panic alerts.
SURESAFEGO_ALERT_EMAIL=suresafe-alerts@your-domain.com

# ─── Timezone ────────────────────────────────────────────────
TZ=Australia/Brisbane
